<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Policies & Safeguarding - St. Eanswythe's</title>
    <style>
        /* General Reset and Base Styles */
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            line-height: 1.6;
            color: #22316C;
            background-color: #f9f9f9;
        }
        h1, h2, h3 { color: #C02C21; margin-bottom: 1rem; }
        p { margin-bottom: 1rem; }

        /* Header & Logo (Matching index.html) */
        header {
            background-color: #f9f9f9;
            color: #22316C;
            padding: 1.5rem;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        .header-logo {
            max-width: 140px; 
            height: auto;
            margin-right: 2rem; 
        }
        .header-text {
            text-align: left;
        }
        header h1 {
            color: #C02C21;
            margin: 0;
            font-size: 2.5rem;
            line-height: 1.2;
        }
        .subtitle {
            margin: 0.2rem 0 0 0;
            font-size: 1.2rem;
            font-weight: 600;
        }
        .strapline {
            margin: 0;
            font-style: italic;
            font-size: 1.05rem;
        }

        /* Navigation */
        nav {
            background-color: #C02C21;
            border-top: 10px solid #22316C;
            border-bottom: 10px solid #22316C;
            position: relative;
        }
        .mobile-menu-toggle {
            display: none; background-color: #C02C21; color: white; border: none;
            font-size: 1.1rem; font-weight: bold; padding: 1rem 1.5rem; width: 100%; text-align: left; cursor: pointer;
        }
        .nav-links { list-style: none; display: flex; justify-content: center; margin: 0; padding: 0; }
        .dropdown { position: relative; display: inline-block; }
        .dropdown > a {
            display: block; color: white; text-decoration: none; padding: 1rem 1.5rem; font-weight: 500; transition: 0.3s;
        }
        .dropdown:hover > a { background-color: #a0241b; color: #fceceb; }
        .dropdown-content {
            display: none; position: absolute; background-color: white; min-width: 220px;
            box-shadow: 0px 8px 16px 0px rgba(34, 49, 108, 0.15); z-index: 10; border-top: 10px solid #22316C;
        }
        .dropdown-content a {
            color: #22316C; padding: 12px 16px; text-decoration: none; display: block; border-bottom: 1px solid #e2e8f0; font-size: 0.95em;
        }
        .dropdown-content a:hover { background-color: #fdf5f5; color: #C02C21; }
        @media (min-width: 769px) { .dropdown:hover .dropdown-content { display: block; } }

        /* Main Layout */
        .container { max-width: 900px; margin: 0 auto; padding: 3rem 2rem; }
        .panel { background: white; padding: 2.5rem; border-radius: 8px; box-shadow: 0 2px 6px rgba(34, 49, 108, 0.1); }

        /* Policy Document List Styles */
        .policy-list {
            display: flex;
            flex-direction: column;
            gap: 1rem;
            margin-top: 2rem;
        }
        
        .policy-item {
            display: flex;
            align-items: center;
            background-color: #fdf5f5;
            border: 1px solid #f0d5d3;
            padding: 1.2rem 1.5rem;
            text-decoration: none;
            color: #22316C;
            font-weight: 600;
            border-radius: 6px;
            transition: all 0.2s ease-in-out;
        }
        
        .policy-item:hover {
            background-color: #C02C21;
            color: white;
            transform: translateX(5px);
            border-color: #C02C21;
            box-shadow: 0 4px 8px rgba(192, 44, 33, 0.2);
        }

        .policy-icon {
            margin-right: 1.2rem;
            font-size: 1.5rem;
        }

        /* Footer */
        footer { background-color: #1a224c; color: white; text-align: center; padding: 2.5rem; border-top: 3px solid #C02C21; }
        footer strong, footer p { color: white; margin-bottom: 0.5rem; }

        /* Responsive Design - Mobile Styling */
        @media (max-width: 768px) {
            /* Mobile Header Centering (Matching index.html) */
            header {
                flex-direction: column;
                align-items: center;
                justify-content: center;
                text-align: center;
                width: 100%;
            }
            .header-logo {
                margin: 0 auto 1rem auto; 
                max-width: 110px;
                display: block;
            }
            .header-text {
                text-align: center;
                width: 100%;
                display: flex;
                flex-direction: column;
                align-items: center;
            }
            header h1 {
                font-size: 2rem;
            }
            
            /* Mobile Navigation */
            .mobile-menu-toggle { display: block; }
            .nav-links { display: none; flex-direction: column; width: 100%; background-color: #a0241b; }
            .nav-links.active { display: flex; }
            .dropdown { width: 100%; display: block; }
            .dropdown > a { border-bottom: 1px solid rgba(255, 255, 255, 0.15); }
            .dropdown-content { position: static; display: none; width: 100%; box-shadow: none; border-top: none; }
            .dropdown-content.show { display: block; }
            .dropdown-content a { padding: 0.8rem 1.5rem 0.8rem 2.5rem; background-color: #fceceb; border-bottom: 1px solid #f0d5d3; }
        }
    </style>
</head>
<body>

    <header>
        <img src="images/stelogo.png" alt="St. Eanswythe's School Logo" class="header-logo">
        <div class="header-text">
            <h1>St. Eanswythe's Primary School</h1>
            <p class="subtitle">Church of England Primary School</p>
            <p class="strapline">Learning Holistically Through God's Unconditional Love.</p>
        </div>
    </header>

    <nav>
        <button class="mobile-menu-toggle">
            <span>☰ Menu</span>
        </button>
        <ul class="nav-links">
            <li class="dropdown">
                <a href="index.html">Home ▾</a>
            </li>
            
            <li class="dropdown">
                <a href="index.html#about">About Us ▾</a>
                <div class="dropdown-content">
                    <a href="index.html#staff">Meet the Staff</a>
                    <a href="index.html#governors">Governors</a>
                    <a href="index.html#admissions">Admissions</a>
                    <a href="policies.html">Policies & Safeguarding</a>
                </div>
            </li>
            
            <li class="dropdown">
                <a href="index.html#curriculum">Learning ▾</a>
            </li>
            
            <li class="dropdown">
                <a href="index.html#parents">Parents Hub ▾</a>
            </li>
            
            <li class="dropdown">
                <a href="index.html#contact">Contact ▾</a>
            </li>
        </ul>
    </nav>

    <main class="container">
        <section class="panel">
            <h2>Policies and Safeguarding</h2>
            <p>At St. Eanswythe's Primary School, we are fully committed to the safety, wellbeing, and success of all our pupils. Below you will find our key school policies available to download and read. If you require a paper copy of any of these documents, please contact the school office.</p>

            <div class="policy-list">
                <a href="Child Protection and Safeguarding Policy.pdf" target="_blank" class="policy-item">
                    <span class="policy-icon">📄</span> Child Protection and Safeguarding Policy
                </a>
                
                <a href="Behaviour Policy.pdf" target="_blank" class="policy-item">
                    <span class="policy-icon">📄</span> Behaviour Policy
                </a>
                
                <a href="Attendance Policy.pdf" target="_blank" class="policy-item">
                    <span class="policy-icon">📄</span> Attendance Policy
                </a>
                
                <a href="Mental Health and Wellbeing Policy.pdf" target="_blank" class="policy-item">
                    <span class="policy-icon">📄</span> Mental Health and Wellbeing Policy
                </a>
            </div>
        </section>
    </main>

    <footer>
        <p><strong>St. Eanswythe's Primary School</strong></p>
        <p>A Church of England Academy, Folkestone</p>
        <p>Tel: 01303 252525 | Email: office@st-eanswythes.kent.sch.uk</p>
        <p style="margin-top: 1rem; font-size: 0.8em; color: #a0aec0;">&copy; 2026 St. Eanswythe's School. All rights reserved.</p>
    </footer>

    <script>
        // Mobile menu toggle script
        document.addEventListener('DOMContentLoaded', () => {
            const dropdowns = document.querySelectorAll('.dropdown');
            const mobileToggle = document.querySelector('.mobile-menu-toggle');
            const navLinks = document.querySelector('.nav-links');

            mobileToggle.addEventListener('click', () => {
                navLinks.classList.toggle('active');
            });

            dropdowns.forEach(dropdown => {
                const triggerLink = dropdown.querySelector('a');
                const content = dropdown.querySelector('.dropdown-content');

                if(content) {
                    triggerLink.addEventListener('click', (e) => {
                        if (window.innerWidth <= 768) {
                            e.preventDefault(); 
                            document.querySelectorAll('.dropdown-content').forEach(menu => {
                                if (menu !== content) menu.classList.remove('show');
                            });
                            content.classList.toggle('show');
                        }
                    });
                }
            });
        });
    </script>
</body>
</html>
